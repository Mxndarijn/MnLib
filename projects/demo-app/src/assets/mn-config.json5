{
  language: {
    urlPattern: "assets/i18n/{locale}.json",
    defaultLocale: "en",
    preload: ["en", "nl"],
    domainLocaleMap: {
      "example.nl": "nl",
      "example.de": "de",
      "example.com": "en"
    }
  },
  "defaults": {
    "test-component": {
      text: "Hello from config!",
      color: "red"
    },
    "mn-input-field": {
      placeholder: "Default placeholder from mn-config1",
      label: "Generic Input",
      ariaLabel: "Global accessible label",
      errorMessages: {
        required: { $translate: "validation.required" },
        email: { $translate: "validation.email" },
        minlength: { $translate: "validation.minlength" },
        maxlength: { $translate: "validation.maxlength" },
        mnMin: { $translate: "validation.mnMin" },
        mnMax: { $translate: "validation.mnMax" }
      }
    },
    "mn-textarea": {
      placeholder: "Default textarea placeholder",
      label: "Generic Textarea",
      errorMessages: {
        required: { $translate: "validation.required" },
        minlength: { $translate: "validation.minlength" },
        maxlength: { $translate: "validation.maxlength" }
      }
    },
    "mn-checkbox": {
      errorMessages: {
        required: { $translate: "validation.required" }
      }
    },
    "mn-datetime": {
      errorMessages: {
        required: { $translate: "validation.required" },
        mnMin: { $translate: "validation.mnMin" },
        mnMax: { $translate: "validation.mnMax" }
      }
    },
    "mn-multi-select": {
      errorMessages: {
        required: { $translate: "validation.multiselect.required" }
      }
    },
    "language-demo-component": {
      label: { $translate: "demo.greeting", params: { name: "Config" } }
    },
    "language-demo-reactive": {
      title: { $translate: "demo.reactive_config.title" },
      description: { $translate: "demo.reactive_config.description" },
      label: { $translate: "demo.reactive_config.label", params: { name: "World" } }
    },
    "mn-dual-horizontal-image": {
      images: [
        { id: '1', url: 'https://www.wildkogel-arena.at/site/assets/files/17949/wildkogelarena_2024-7237.1920x0-sp.jpg', alt: 'Image 1' },
        { id: '2', url: 'https://6hsport15.wordpress.com/wp-content/uploads/2016/01/skic3abn.jpg?w=617&h=411', alt: 'Image 2' }
      ]
    },
    "mn-calendar": {
      startHour: 7,
      endHour: 22,
      locale: "en-US",
      todayLabel: { $translate: "calendar.today" },
      upcomingEventsTitle: { $translate: "calendar.upcoming_events" },
      viewLabels: {
        MONTH: { $translate: "calendar.view.month" },
        WEEK: { $translate: "calendar.view.week" },
        DAY: { $translate: "calendar.view.day" }
      },
      mobileBreakpoint: 768
    }
  },
  "overrides": {
    root: {
      "section-a": {
        "#header-text": {
          "text": "Overridden config text!"
        },
        "#mn-input-email": {
          label: "Email Address",
          placeholder: "Enter your email",
          ariaLabel: "Your email address"
        }
      },
      "section-b": {
        "test-component": {
          color: "blue",
          text: "Overridden config 1!"
        }
      },
      "language-demo": {
        "#mn-input-demo-name": {
          placeholder: { $translate: "demo.form.name.placeholder" },
          label: { $translate: "demo.form.name.label" }
        },
        "#mn-textarea-demo-message": {
          placeholder: { $translate: "demo.form.message.placeholder" },
          label: { $translate: "demo.form.message.label" }
        },
        "#mn-input-validation-name": {
          label: { $translate: "demo.validation.name.label" },
          placeholder: { $translate: "demo.validation.name.placeholder" }
        },
        "#mn-input-validation-email": {
          label: { $translate: "demo.validation.email.label" },
          placeholder: { $translate: "demo.validation.email.placeholder" }
        },
        "#mn-textarea-validation-message": {
          label: { $translate: "demo.validation.message.label" },
          placeholder: { $translate: "demo.validation.message.placeholder" }
        }
      }
    }
  }
}
